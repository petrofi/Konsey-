# ============================================
# Konsey Tartışma Sistemi - Environment Config
# ============================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# The system works without API keys (uses fallback templates),
# but for real AI responses you need at least one key.

# ----- Claude API (Anthropic) -----
# Get your key at: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-opus-20240229

# ----- Google Gemini API -----
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# ----- Groq API (used for Grok agent) -----
# Get your key at: https://console.groq.com
# Note: This uses Groq's inference API. The agent is named "Grok" in the UI.
GROK_API_KEY=your_groq_api_key_here
GROK_MODEL=llama-3.1-70b-versatile

# ----- Server Configuration -----
PORT=3000
NODE_ENV=development

# ----- Logging -----
DEBUG=false
LOG_LEVEL=info

# ----- CORS Settings -----
CORS_ORIGIN=http://localhost:3000

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
